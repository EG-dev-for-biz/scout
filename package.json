    "electron": "^35.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "eslint": "^9.19.0",
    "globals": "^15.14.0",
    "typescript": "~5.7.2"
  },
  "build": {
    "appId": "com.scout3d.app",
    "productName": "Scout3D",
